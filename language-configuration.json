{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["{","}"],
    ["[","]"],
    ["(",")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"", "notIn": ["string"] },
    { "open": "'", "close": "'", "notIn": ["string"] }
  ],
  "surroundingPairs": [
    ["{","}"],
    ["[","]"],
    ["(",")"],
    ["\"","\""],
    ["'","'"]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(class|struct|implement|impl|enum|fun|async\\s+fun|if|else|for|foreach|match|module)\\b.*:\\s*$",
    "decreaseIndentPattern": "^\\s*(else)\\s*$"
  }
}
